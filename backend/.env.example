# Copy to `.env` and fill in. `.env` is git-ignored and must never be committed.

# --- Django --------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-generate-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# --- Database (local XAMPP MariaDB) --------------------------------------
DB_ENGINE=django.db.backends.mysql
DB_NAME=brevet_gpt
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# --- Corpus --------------------------------------------------------------
# Root containing english/ and french/ (defaults to <repo>/assets when unset).
ASSETS_DIR=E:/AI Projects/Brevet-gpt/assets
# Clean OCR'd PDFs produced by gpu_ocr_books.py (contains eng/ and fr/).
RESULTS_DIR=C:/Users/Admin/Documents/books/results

# --- Vector store (ChromaDB, persistent local) ---------------------------
CHROMA_DIR=E:/AI Projects/Brevet-gpt/chroma
CHROMA_COLLECTION=brevet

# --- Embeddings ----------------------------------------------------------
# "local" = sentence-transformers on CPU (offline, no API); "openai" = API.
EMBEDDING_BACKEND=local
LOCAL_EMBED_MODEL=BAAI/bge-m3
EMBED_CHUNK_TOKENS=512
EMBED_CHUNK_OVERLAP=64

# Only used when EMBEDDING_BACKEND=openai.
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-large

# --- Generation (LM Studio, OpenAI-compatible local server) --------------
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# --- Retrieval -----------------------------------------------------------
RAG_CANDIDATES=20
RAG_TOP_K=6
RAG_MAX_CONTEXT_TOKENS=3000
RAG_MIN_RELEVANCE=0.25
RAG_MAX_REFORMULATIONS=2

# --- Agentic RAG (set RAG_AGENTIC=False for the original linear pipeline) -
RAG_AGENTIC=True
RAG_RERANK=True
RAG_RERANK_BACKEND=cross_encoder
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_CANDIDATES=12
RAG_DENSE_SIM_WEIGHT=0.3
RAG_GRADE_CONTEXT=True
RAG_GRADE_MAX_CHUNKS=4
RAG_SUFFICIENCY_MIN=0.5
RAG_AGENT_MAX_LOOPS=1
RAG_REASON=True
RAG_REASON_SUBJECTS=math,physics,chemistry
RAG_REASON_MAX_TOKENS=512
RAG_VERIFY=True
RAG_VERIFY_MIN=0.5
RAG_VERIFY_MAX_CLAIMS=6
RAG_VERIFY_ACTION=warn
RAG_AGENT_LLM_BUDGET=8
